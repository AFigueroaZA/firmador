# Variables de entorno para el sitio de Netlify (proyectofirmador.netlify.app)
# Netlify NO lee este archivo automaticamente: cargalas a mano en
# Site configuration > Environment variables (o con `netlify env:set`).
# Se comparten entre el build, la funcion SSR de @firmador/web y la funcion
# serverless de @firmador/api (netlify/functions/api.mjs).

# --- Enlace entre web y api (misma URL, la api queda detras de /api) ---
API_BASE_URL=https://proyectofirmador.netlify.app/api
WEB_BASE_URL=https://proyectofirmador.netlify.app
CORS_ORIGIN=https://proyectofirmador.netlify.app
COOKIE_SECURE=true

# --- Seguridad / sesiones ---
ENCRYPTION_KEY=

# --- Proveedor de firma ---
SIGNING_PROVIDER_MODE=mock
TEMP_FILE_TTL_HOURS=24

# --- Base de datos (Supabase Postgres) ---
DATABASE_SYNCHRONIZE=false
DATABASE_URL=
DATABASE_SCHEMA=public
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

# --- Proveedor e-sign (solo si SIGNING_PROVIDER_MODE=live) ---
PROVIDER_ALLOW_INSECURE_TLS=false
PROVIDER_CLAVE_UNICA_BASE_URL=https://checkmiid.cl:8443/ClaveUnica
PROVIDER_CHALLENGE_BASE_URL=https://idfd.e-sign.cl:8443/esign-api-mvn/rest-services
PROVIDER_RA_URL=https://ra.e-sign.cl:8543/esign-ra/WSIngresoSolicitud
PROVIDER_ESIGNER_URL=https://ws.esigner.cl:8543/esign-orq
PROVIDER_ORIGIN=
PROVIDER_RUT_EMPRESA=
PROVIDER_USERNAME=
PROVIDER_PASSWORD=
PROVIDER_CERT_DOWNLOAD_USER=
PROVIDER_CERT_DOWNLOAD_PASSWORD=
PROVIDER_PIN_FIRMA=
PROVIDER_CERT_TYPE=FEA
PROVIDER_QR_ENABLED=false
PROVIDER_QR_X=
PROVIDER_QR_Y=
DEFAULT_CERTIFICATE_PASSWORD=
CERTIFICATE_VALIDITY_DAYS=365
