---
interface Props {
  title: string;
  value: string;
  subtitle: string;
}

const { title, value, subtitle } = Astro.props as Props;
---

<article class="panel animate-rise px-5 py-5">
  <p class="text-sm text-slate-500">{title}</p>
  <p class="mt-3 text-3xl font-semibold text-ink">{value}</p>
  <p class="mt-2 text-sm text-slate-500">{subtitle}</p>
</article>
