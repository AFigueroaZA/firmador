---
interface Props {
  label?: string;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const {
  label = "Cargando",
  size = "md",
  class: className = "",
} = Astro.props as Props;
const sizeClasses = {
  sm: "h-4 w-4 border-2",
  md: "h-7 w-7 border-[3px]",
  lg: "h-11 w-11 border-4",
};
---

<span
  class:list={["inline-flex items-center justify-center gap-3", className]}
  role="status"
  aria-live="polite"
>
  <span
    class:list={[
      "inline-block animate-spin rounded-full border-current border-r-transparent motion-reduce:animate-none",
      sizeClasses[size],
    ]}
    aria-hidden="true"
  ></span>
  {label && <span>{label}</span>}
</span>
