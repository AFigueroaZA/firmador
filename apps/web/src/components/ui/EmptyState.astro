---
interface Props {
  title: string;
  description?: string;
  class?: string;
}

const { title, description, class: className = "" } = Astro.props;
---

<div class:list={["px-6 py-10 text-center", className]}>
  <p class="font-semibold text-ink">{title}</p>
  {description && <p class="mx-auto mt-2 max-w-lg text-sm text-slate-500">{description}</p>}
  <div class="mt-5 empty:hidden"><slot /></div>
</div>
