---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  class?: string;
}

const { eyebrow, title, description, class: className = "" } = Astro.props;
---

<header class:list={["flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between", className]}>
  <div class="min-w-0">
    {eyebrow && <p class="text-xs font-semibold uppercase tracking-[0.14em] text-coral-700">{eyebrow}</p>}
    <h1 class:list={[eyebrow && "mt-2", "text-3xl font-semibold tracking-tight text-ink sm:text-4xl"]}>{title}</h1>
    {description && <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-500">{description}</p>}
  </div>
  <div class="shrink-0 empty:hidden"><slot name="actions" /></div>
</header>
