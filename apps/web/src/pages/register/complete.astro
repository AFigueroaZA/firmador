---
import AppLayout from "../../layouts/AppLayout.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import { serverFetch } from "../../lib/server/api";

interface RegistrationStatus {
  status: "VALIDATED" | "COMPLETED";
  profile: {
    rut?: string | null;
    nombres?: string | null;
    apellidoPaterno?: string | null;
    apellidoMaterno?: string | null;
    email?: string | null;
    telefono?: string | null;
    numeroDocumento?: string | null;
    fechaNacimiento?: string | null;
    estadoCivil?: string | null;
  };
  missingFields: string[];
}

const state = Astro.url.searchParams.get("state") ?? "";
if (!state) {
  return Astro.redirect("/?error=registration");
}

const response = await serverFetch(Astro.request, `/api/registration/${state}`);
if (!response.ok) {
  return Astro.redirect("/?error=registration");
}

const registration = (await response.json()) as RegistrationStatus;
const profile = registration.profile;
---

<AppLayout title="Completar registro">
  <section class="mx-auto max-w-3xl space-y-5">
    <PageHeader eyebrow="Paso 2 de 2" title="Completa tu registro" description="Tu identidad ya fue validada. Completa la información necesaria para crear tu cuenta." />
    <article class="panel animate-rise px-6 py-6">
      <h2 class="text-lg font-semibold text-ink">Identidad validada</h2>
      <dl class="mt-5 grid gap-3 text-sm text-slate-600 md:grid-cols-2">
        <div class="rounded-2xl bg-slate-50 px-4 py-3">
          <dt class="font-semibold text-slate-700">RUN</dt>
          <dd>{profile.rut}</dd>
        </div>
        <div class="rounded-2xl bg-slate-50 px-4 py-3">
          <dt class="font-semibold text-slate-700">Nombre</dt>
          <dd>{[profile.nombres, profile.apellidoPaterno, profile.apellidoMaterno].filter(Boolean).join(" ")}</dd>
        </div>
      </dl>
    </article>

    <form class="panel animate-rise space-y-5 px-6 py-6" data-state={state} id="registration-complete-form">
      <div class="grid gap-4 md:grid-cols-2">
        <label class="text-sm font-medium text-slate-700">
          Correo
          <input class="field mt-2" name="email" required type="email" value={profile.email ?? ""} />
        </label>
        <label class="text-sm font-medium text-slate-700">
          Contrasena
          <input class="field mt-2" name="password" minlength="8" required type="password" />
        </label>
        <label class="text-sm font-medium text-slate-700">
          Telefono celular
          <input
            class="field mt-2"
            inputmode="numeric"
            name="telefono"
            pattern="9[0-9]{8}"
            placeholder="912345678"
            required
            title="Celular chileno de 9 dígitos, comenzando con 9 (ej: 912345678)"
            value={profile.telefono ?? ""}
          />
          <span class="mt-1 block text-xs font-normal text-slate-500">9 dígitos, sin +56 (ej: 912345678)</span>
        </label>
        <label class="text-sm font-medium text-slate-700">
          Numero de documento (serie de la cedula)
          <input
            class="field mt-2"
            name="numeroDocumento"
            pattern="[A-Za-z]?[0-9.\-\s]{6,13}"
            placeholder="A012345678"
            required
            title="Número de documento/serie de tu cédula, ej: A012345678 o 123456789"
            value={profile.numeroDocumento ?? ""}
          />
          <span class="mt-1 block text-xs font-normal text-slate-500">Aparece en el frente de tu cédula (ej: A012345678)</span>
        </label>
        <label class="text-sm font-medium text-slate-700">
          Fecha de nacimiento
          <input class="field mt-2" name="fechaNacimiento" required type="date" value={profile.fechaNacimiento ?? ""} />
        </label>
        <label class="text-sm font-medium text-slate-700">
          Estado civil
          <select class="field mt-2" name="estadoCivil" required>
            <option value="">Selecciona una opción</option>
            {["Soltero", "Casado", "Divorciado", "Viudo", "Separado", "Conviviente Civil"].map((option) => (
              <option selected={profile.estadoCivil === option} value={option}>{option}</option>
            ))}
          </select>
        </label>
      </div>

      <div class="hidden rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700" id="registration-complete-error"></div>
      <button class="button-accent" type="submit">Crear cuenta</button>
    </form>
  </section>

  <script is:inline>
    const form = document.querySelector("#registration-complete-form");
    const errorBox = document.querySelector("#registration-complete-error");
    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      errorBox?.classList.add("hidden");

      const state = form.getAttribute("data-state") || "";
      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());
      const response = await fetch(`/api/registration/${state}/complete`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        if (errorBox) {
          let detail = "";
          try {
            const body = await response.json();
            detail = Array.isArray(body.message)
              ? body.message.join(" ")
              : (body.message ?? "");
          } catch {
            detail = "";
          }
          errorBox.textContent = response.status === 409
            ? "Ya existe una cuenta con estos datos."
            : detail || "No se pudo completar el registro.";
          errorBox.classList.remove("hidden");
        }
        return;
      }

      window.location.assign("/enrollment/challenge");
    });
  </script>
</AppLayout>
