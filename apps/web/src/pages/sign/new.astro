---
import AppLayout from "../../layouts/AppLayout.astro";
import { SignWizard } from "../../components/islands/SignWizard";
---

<AppLayout title="Nuevo proceso de firma" user={Astro.locals.user}>
  <section class="space-y-4">
    <div class="panel animate-rise px-6 py-5">
      <h2 class="text-lg font-semibold text-ink">Carga y configuración</h2>
      <p class="mt-2 text-sm text-slate-600">
        Define si la firma será visible, la página, la posición y una imagen opcional antes de salir al proveedor.
      </p>
    </div>
    <SignWizard client:load createEndpoint="/api/signing/processes" />
  </section>
</AppLayout>

