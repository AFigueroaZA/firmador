---
import AppLayout from "../../../layouts/AppLayout.astro";
---

<AppLayout title="Procesando firma" user={Astro.locals.user}>
  <section class="mx-auto max-w-2xl">
    <div class="panel animate-rise px-6 py-6">
      <h2 class="text-lg font-semibold text-ink">Estamos cerrando el proceso</h2>
      <p class="mt-3 text-sm text-slate-600">
        El backend está comunicándose con RA, certificado y motor de firma. Esta vista se actualizará sola.
      </p>
      <div class="mt-6 rounded-3xl bg-slate-100 p-4">
        <div class="h-3 overflow-hidden rounded-full bg-white">
          <div class="h-full w-2/3 animate-pulse rounded-full bg-accent"></div>
        </div>
      </div>
      <p class="mt-4 text-sm text-slate-500" id="status-copy">Consultando estado...</p>
    </div>
  </section>

  <script is:inline data-process-id={Astro.params.processId}>
    const processId = document.currentScript?.getAttribute("data-process-id") ?? "";
    const statusCopy = document.querySelector("#status-copy");
    const poll = async () => {
      const response = await fetch(`/api/signing/processes/${processId}`);
      if (!response.ok) {
        window.location.assign("/history");
        return;
      }

      const process = await response.json();
      statusCopy.textContent = `Estado actual: ${process.status}`;
      if (["SIGNED", "FAILED", "EXPIRED"].includes(process.status)) {
        window.location.assign(`/sign/${processId}/result`);
        return;
      }

      window.setTimeout(poll, 1800);
    };

    void poll();
  </script>
</AppLayout>
