---
import type { IdentityStatusResponse } from "@firmador/shared";
import AppLayout from "../layouts/AppLayout.astro";
import InfoCard from "../components/InfoCard.astro";
import { serverFetch } from "../lib/server/api";

interface HistoryResponse {
  items: Array<{ status: string }>;
}

const historyResponse = await serverFetch(Astro.request, "/api/history");
const identityResponse = await serverFetch(Astro.request, "/api/identity/me");
const history = historyResponse.ok
  ? ((await historyResponse.json()) as HistoryResponse)
  : { items: [] };
const identity = identityResponse.ok
  ? ((await identityResponse.json()) as IdentityStatusResponse)
  : null;

const total = history.items.length;
const signed = history.items.filter((item) => item.status === "SIGNED").length;
const pending = history.items.filter((item) =>
  [
    "CONFIGURED",
    "EXTERNAL_AUTH_PENDING",
    "CHALLENGE_PENDING",
    "RA_PENDING",
    "CERT_PENDING",
    "SIGNING",
  ].includes(item.status),
).length;
---

<AppLayout title="Dashboard operativo" user={Astro.locals.user}>
  <section class="grid gap-4 lg:grid-cols-3">
    <InfoCard title="Procesos totales" value={String(total)} subtitle="Historial del usuario o del entorno admin" />
    <InfoCard title="Firmas exitosas" value={String(signed)} subtitle="Documentos listos para descarga" />
    <InfoCard title="En curso" value={String(pending)} subtitle="Procesos esperando interaccion o proveedor" />
  </section>

  <section class="mt-6 grid gap-4 lg:grid-cols-[minmax(0,1fr),320px]">
    <article class="panel animate-rise px-6 py-6">
      <h2 class="text-lg font-semibold text-ink">
        {identity?.canSign ? "Flujo principal" : "Habilitacion requerida"}
      </h2>
      <ol class="mt-4 space-y-3 text-sm text-slate-600">
        <li>1. Valida identidad y completa perfil.</li>
        <li>2. Carga un PDF y configura la firma visible.</li>
        <li>3. Confirma el pago demo o saldo disponible.</li>
        <li>4. Descarga el PDF firmado desde el resultado.</li>
      </ol>
      <div class="mt-6 flex flex-wrap gap-3">
        {identity?.canSign ? (
          <a class="button-primary" href="/sign/new">Firmar un PDF</a>
        ) : (
          <a class="button-primary" href="/identity?next=/sign/new">Validar identidad</a>
        )}
        <a class="button-secondary" href="/history">Ver historial</a>
      </div>
    </article>

    <aside class="panel animate-rise px-6 py-6">
      <h2 class="text-lg font-semibold text-ink">Trazabilidad</h2>
      <p class="mt-3 text-sm text-slate-600">
        El sistema guarda estados, errores y metadatos, y el almacenamiento queda encapsulado para migrarlo despues.
      </p>
    </aside>
  </section>
</AppLayout>
